# ============================================================
# .env.example — шаблон переменных окружения
# ============================================================
# Это публичный файл (в репозитории). Реальные значения здесь
# НЕ хранить — только placeholder'ы и комментарии.
#
# Как использовать:
#   1. Скопируйте этот файл в .env:
#        cp .env.example .env
#   2. Заполните реальными значениями.
#   3. Никому не показывайте .env.
# ============================================================


# --- Telegram-бот ---

# Токен бота от @BotFather.
# Формат: <bot_id>:<auth_string>, например 1234567890:AAEXxx_YyyZzz
# Получить: написать @BotFather → /newbot → следовать инструкциям.
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Username бота без @.
# Используется для построения ссылок t.me/<username>
# и t.me/<username>/<app> для Mini App.
TELEGRAM_BOT_USERNAME=your_bot_username

# Chat ID администратора, куда падают заявки на бронь и вопросы.
# Как узнать: напишите боту @userinfobot — он пришлёт ваш chat_id.
# Для группы: пригласите @raw_data_bot в чат, он выдаст group chat_id.
ADMIN_CHAT_ID=000000000


# --- Telegram Mini App ---

# Публичный HTTPS-URL, на котором развёрнут TMA.
# Указывается в @BotFather через /newapp → URL.
# Локально для тестов — используйте cloudflared/ngrok туннель.
TMA_URL=https://your-mini-app.example.com


# --- Контакты ресторана (опционально) ---
# Если бот будет использовать в ответах.
RESTAURANT_PHONE=+70000000000
RESTAURANT_NAME=Название ресторана
